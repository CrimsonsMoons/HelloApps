<Window x:Class="AevraPCNotify.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Aevra PC Notify" Width="620" Height="650" WindowStartupLocation="CenterScreen"
 Background="#090B10">
 <Window.Resources>
  <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/><Setter Property="FontFamily" Value="Segoe UI"/></Style>
  <Style TargetType="TextBox"><Setter Property="Background" Value="#161A22"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#2B3140"/><Setter Property="Padding" Value="12"/><Setter Property="FontSize" Value="14"/></Style>
  <Style TargetType="Button"><Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#090B10"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="15,12"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/></Style>
 </Window.Resources>
 <ScrollViewer VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="30">
   <TextBlock Text="Aevra PC Notify" FontSize="30" FontWeight="Bold"/>
   <TextBlock Text="Automatically finds Aevra over Wi-Fi, then falls back to Bluetooth." Foreground="#9AA4B5" Margin="0,7,0,22" TextWrapping="Wrap"/>

   <Border Background="#121620" CornerRadius="14" Padding="16" Margin="0,0,0,16">
    <StackPanel>
     <TextBlock Text="Connection" FontSize="17" FontWeight="SemiBold"/>
     <TextBlock x:Name="ConnectionText" Text="Not connected" Foreground="#9AA4B5" Margin="0,6,0,12"/>
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="Find iPhone" Click="Discover_Click"/>
      <Button Grid.Column="2" Content="Test connection" Background="#242A35" Foreground="White" Click="Test_Click"/>
     </Grid>
    </StackPanel>
   </Border>

   <TextBlock Text="Pairing code" Margin="0,0,0,7"/>
   <TextBox x:Name="CodeBox" MaxLength="8" Margin="0,0,0,15"/>
   <TextBlock Text="Notification title" Margin="0,0,0,7"/>
   <TextBox x:Name="TitleBox" Text="Message from your PC" Margin="0,0,0,15"/>
   <TextBlock Text="Message" Margin="0,0,0,7"/>
   <TextBox x:Name="MessageBox" Text="Aevra notification test" Height="120" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,16"/>
   <Button x:Name="SendButton" Content="Send notification" Click="Send_Click"/>

   <Border Background="#121620" CornerRadius="14" Padding="16" Margin="0,16,0,0">
    <StackPanel>
     <TextBlock Text="Status" FontWeight="SemiBold"/>
     <TextBlock x:Name="StatusText" Text="Open Aevra on your iPhone, go to Live, and copy its pairing code." Foreground="#9AA4B5" Margin="0,6,0,0" TextWrapping="Wrap"/>
    </StackPanel>
   </Border>
  </StackPanel>
 </ScrollViewer>
</Window>
